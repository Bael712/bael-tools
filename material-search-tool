  <meta name="description" content="音神 蛍（BAEL）が作ったトーラムの素材検索ツール。装備素材をサクッと検索！ギルドやプレイヤー向けに最適化。">
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(to bottom, #1a202c, #2d3748);
      color: #e2e8f0;
      font-family: 'Arial', sans-serif;
    }
    .light body {
      background: linear-gradient(to bottom, #e2e8f0, #edf2f7);
      color: #1a4731;
    }
    .toram-logo {
      max-width: 200px;
      margin: 0 auto;
    }
    .tool-card {
      transition: transform 0.3s;
      min-width: 250px;
      height: 100%; /* カードの高さを揃える */
    }
    .tool-card:hover {
      transform: scale(1.05);
    }
    .tool-card {
      scroll-snap-align: start;
      background-color: #1a4731; /* ダークモード */
      color: #e2e8f0;
    }
    .light .tool-card {
      background-color: #d1fae5; /* ライトモード*/
      color: #1a4731;
    }
    .tool-card a {
      color: #60a5fa;
    }
    .tool-card a:hover {
      color: #3b82f6;
      text-shadow: 0 0 5px #10b981;
    }
    .light .tool-card a {
      color: #2f855a;
    }
    .light .tool-card a:hover {
      color: #276749;
      text-shadow: 0 0 5px #34d399;
    }
    #contact a:hover {
      text-shadow: 0 0 5px #10b981;
    }
    .light #contact a:hover {
      text-shadow: 0 0 5px #34d399;
    }
    .light h1 {
      color: #10b981;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <!-- ヘッダー -->
  <header class="bg-gray-900 dark:bg-gray-800 p-4 shadow-md">
