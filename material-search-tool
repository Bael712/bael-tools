  <!-- フッター -->
  <footer class="bg-gray-900 dark:bg-gray-800 p-4 mt-auto">
    <div class="container mx-auto text-center">
      <p>&copy; 2025 BAELの便利ツール. Made for Toram Online players.</p>
      <p>こちらのページ・ツールは <a href="https://x.ai/grok" class="text-blue-400 hover:text-blue-300 dark:text-green-300 dark:hover:text-green-200">Grok</a> と共に生成しております。</p>
    </div>
  </footer>

  <!-- ダークモード切り替えスクリプト（カルーセル分は削除） -->
  <script>
    // ダークモード切り替え
    const toggleButton = document.getElementById('theme-toggle');
    const html = document.documentElement;
    if (localStorage.getItem('theme') === 'light') {
      html.classList.remove('dark');
      html.classList.add('light');
      toggleButton.textContent = 'ダークモード';
    }
    toggleButton.addEventListener('click', () => {
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        html.classList.add('light');
        localStorage.setItem('theme', 'light');
        toggleButton.textContent = 'ダークモード';
      } else {
        html.classList.remove('light');
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
        toggleButton.textContent = 'ライトモード';
      }
    });
  </script>
</body>
</html>
